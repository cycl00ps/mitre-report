{
  "$schema": "https://opencode.ai/config.json",

  "model": "lab02/primary-model",
  "small_model": "lab01/light-model",

  "enabled_providers": ["lab01", "lab02"],
  "provider": {
    "lab01": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "lab01",
      "options": {
        "baseURL": "https://DOMAIN/v1",
        "apiKey": "nothing"
      },
      "models": {
        "light-model": {
          "id": "gemma-4-26B-A4B-it-UD-Q8_K_XL",
          "name": "gemma-4-26B-A4B-it-UD-Q8_K_XL"
        }
      }
    },

    "lab02": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "lab02",
      "options": {
        "baseURL": "https://DOMAIN/v1",
        "apiKey": "nothing"
      },
      "models": {
        "primary-model": {
          "id": "Qwen3.5-122B-A10B-UD-Q6_K_XL",
          "name": "Qwen3.5-122B-A10B-UD-Q6_K_XL"
        }
      }
    }
  },

  "permission": {
    "external_directory": "deny",

    "bash": {
      "*": "allow",
      "sudo *": "deny",
      "rm -rf *": "deny",
      "rm -rf": "deny",
      "chmod *": "deny",
      "chown *": "deny",
      "mkfs *": "deny",
      "dd if=": "deny",
      "git *": "allow",
      "npm *": "allow",
      "yarn *": "allow",
      "pnpm *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "cd *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "test *": "allow",
      "make *": "allow",
      "docker *": "allow",
      "docker-compose *": "allow"
    },

    "edit": {
      "*": "allow"
    },

    "write": {
      "*": "allow"
    },

    "webfetch": "allow",
    "websearch": "allow"
  }
}
